{
  "name": "neuraflash-field-forms",
  "version": "3.1.0",
  "private": true,
  "description": "NeuraFlash Field Forms - drag-and-drop form builder and runtime for Salesforce Field Service.",
  "scripts": {
    "lint": "eslint field-forms/lwc",
    "lint:offline": "eslint --rulesdir node_modules/@salesforce/eslint-plugin-lwc-graph-analyzer/lib/rules field-forms/lwc",
    "test:unit": "sfdx-lwc-jest --skipApiVersionCheck",
    "test:unit:watch": "sfdx-lwc-jest --skipApiVersionCheck --watch",
    "test:unit:coverage": "sfdx-lwc-jest --skipApiVersionCheck --coverage"
  },
  "devDependencies": {
    "@lwc/eslint-plugin-lwc": "^1.7.2",
    "@prettier/plugin-xml": "^3.2.2",
    "@salesforce/eslint-config-lwc": "^3.5.3",
    "@salesforce/eslint-plugin-aura": "^2.1.0",
    "@salesforce/eslint-plugin-lightning": "^1.0.0",
    "@salesforce/eslint-plugin-lwc-graph-analyzer": "^1.0.0",
    "@salesforce/sfdx-lwc-jest": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.6.0",
    "prettier": "^3.3.3",
    "prettier-plugin-apex": "^2.1.5"
  }
}
