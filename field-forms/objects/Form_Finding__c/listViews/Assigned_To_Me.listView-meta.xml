         metadata. Surface the assignee as a column for triage instead. -->
    <filters>
        <field>Status__c</field>
        <operation>notEqual</operation>
        <value>Resolved,Resolved-Exception,Auto-Resolved,Waived</value>
    </filters>
    <label>Open by Assignee</label>
</ListView>
