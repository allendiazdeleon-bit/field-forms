            </value>
            <value>
                <fullName>In Progress</fullName>
                <default>false</default>
                <label>In Progress</label>
            </value>
            <value>
                <fullName>Resolved</fullName>
                <default>false</default>
                <label>Resolved</label>
            </value>
            <value>
                <fullName>Auto-Resolved</fullName>
                <default>false</default>
                <label>Auto-Resolved</label>
            </value>
            <value>
                <fullName>Resolved-Exception</fullName>
                <default>false</default>
                <label>Resolved-Exception</label>
            </value>
            <value>
