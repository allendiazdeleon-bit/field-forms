<apex:page controller="NeuraFormPdfController"
           renderAs="pdf"
           applyHtmlTag="true"
           showHeader="false"
           sidebar="false"
           standardStylesheets="false">
    <head>
        <style type="text/css">
            @page {
                size: letter portrait;
                margin: 0.75in 0.6in;
                @bottom-right {
                    content: "Page " counter(page) " of " counter(pages);
                    font-family: Arial, sans-serif;
                    font-size: 9pt;
                    color: #888;
                }
            }
            body {
                font-family: Arial, Helvetica, sans-serif;
                font-size: 10pt;
                color: #181818;
                margin: 0;
                padding: 0;
            }
            .header {
                border-bottom: 2px solid #0070d2;
                padding-bottom: 8pt;
                margin-bottom: 14pt;
            }
            .header h1 {
                margin: 0;
                font-size: 18pt;
                color: #0070d2;
            }
            .header .meta {
                font-size: 9pt;
                color: #555;
                margin-top: 4pt;
            }
            .summary-box {
                background: #f5f9ff;
                border: 1px solid #c9def7;
                border-radius: 4pt;
                padding: 8pt 10pt;
                margin-bottom: 14pt;
            }
            .summary-box h2 {
                font-size: 10pt;
                color: #0070d2;
                margin: 0 0 4pt;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }
            .summary-box p {
                margin: 0;
                font-size: 10pt;
                line-height: 1.4;
            }
            .page-group { page-break-inside: avoid; margin-bottom: 12pt; }
            .page-group h2 {
                font-size: 13pt;
                margin: 12pt 0 6pt;
                padding-bottom: 3pt;
                border-bottom: 1px solid #e5e5e5;
                color: #181818;
            }
            .section-group { margin-bottom: 8pt; }
            .section-group h3 {
                font-size: 11pt;
                margin: 8pt 0 4pt;
                color: #444;
            }
            table.answers {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 4pt;
            }
            table.answers td {
                padding: 5pt 6pt;
                vertical-align: top;
                border-bottom: 1px solid #f0f0f0;
            }
            table.answers td.label {
                width: 38%;
                color: #555;
                font-size: 9pt;
            }
            table.answers td.value {
                color: #181818;
                font-size: 10pt;
                font-weight: 500;
            }
            .comment {
                font-size: 9pt;
                color: #888;
                font-style: italic;
                display: block;
                margin-top: 2pt;
            }
            .footer-note {
                margin-top: 18pt;
                font-size: 8pt;
                color: #888;
                border-top: 1px solid #e5e5e5;
                padding-top: 6pt;
            }
        </style>
    </head>
    <body>
        <div class="header">
            <h1>{!data.templateName}</h1>
            <div class="meta">
                <apex:outputText value="Form: {!data.linkedFormName}"/>
                <apex:outputPanel rendered="{!NOT(ISBLANK(data.workOrderNumber))}">
                    &nbsp;|&nbsp;
                    <apex:outputText value="Work Order: {!data.workOrderNumber}"/>
                </apex:outputPanel>
                &nbsp;|&nbsp;
                <apex:outputText value="Status: {!data.status}"/>
                <br/>
                <apex:outputText value="Completed: {0,date,MMM d, yyyy h:mm a}">
                    <apex:param value="{!data.completedDate}"/>
                </apex:outputText>
            </div>
        </div>

        <apex:outputPanel rendered="{!NOT(ISBLANK(data.serviceSummary))}">
            <div class="summary-box">
                <h2>Service Summary</h2>
                <p>{!data.serviceSummary}</p>
            </div>
        </apex:outputPanel>

        <apex:repeat value="{!data.pages}" var="pg">
            <div class="page-group">
                <h2>{!pg.title}</h2>
                <apex:repeat value="{!pg.sections}" var="sec">
                    <div class="section-group">
                        <apex:outputPanel rendered="{!NOT(ISBLANK(sec.title))}">
                            <h3>{!sec.title}</h3>
                        </apex:outputPanel>
                        <table class="answers">
                            <apex:repeat value="{!sec.rows}" var="row">
                                <tr>
                                    <td class="label">{!row.label}</td>
                                    <td class="value">
                                        {!row.value}
                                        <apex:outputPanel rendered="{!NOT(ISBLANK(row.comment))}">
                                            <span class="comment">Note: {!row.comment}</span>
                                        </apex:outputPanel>
                                    </td>
                                </tr>
                            </apex:repeat>
                        </table>
                    </div>
                </apex:repeat>
            </div>
        </apex:repeat>

        <div class="footer-note">
            Generated by NeuraFlash Field Forms.
        </div>
    </body>
</apex:page>
